<Window x:Class="POEPART2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSafe" Height="500" Width="700"
        Background="#1A1A1A">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name entry panel, hidden after users name is set -->
        <StackPanel x:Name="namePanel" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Enter your name: " VerticalAlignment="Center" Foreground="#FFA500"/>
            <TextBox x:Name="nameBox" Width="200" Margin="5,0"
                     Background="#2B2B2B" Foreground="#FFFFFF"
                     CaretBrush="#FFA500" BorderBrush="#FFA500"
                     KeyDown="nameBox_KeyDown"/>
            <Button Content="Start Chat" Click="StartChat_Click"
                    Background="#FFA500" Foreground="#1A1A1A"
                    BorderThickness="0" Padding="8,4"/>
        </StackPanel>

        <!-- Chat log area -->
        <TextBox x:Name="chatLog"
                 Grid.Row="1"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,10"
                 Foreground="#FFD700"
                 BorderBrush="#FFA500"
                 CaretBrush="#FFA500">
            <TextBox.Background>
                <ImageBrush ImageSource="Images/Locksmith.png"
                            Opacity="0.2"
                            Stretch="UniformToFill"/>
            </TextBox.Background>
        </TextBox>

        <!-- Input area, disabled until a users name is entered -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="inputBox"
                     Grid.Column="0"
                     IsEnabled="False"
                     TextWrapping="Wrap"
                     KeyDown="inputBox_KeyDown"
                     Margin="0,0,5,0"
                     Background="#2B2B2B" Foreground="#FFFFFF"
                     CaretBrush="#FFA500" BorderBrush="#FFA500"/>
            <Button x:Name="sendButton"
                    Grid.Column="1"
                    Content="Send"
                    IsEnabled="False"
                    Click="SendButton_Click"
                    Background="#FFA500" Foreground="#1A1A1A"
                    BorderThickness="0" Padding="8,4"/>
        </Grid>
    </Grid>

</Window>